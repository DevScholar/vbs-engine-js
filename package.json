{
  "name": "@devscholar/vbs-engine-js",
  "description": "A VBScript engine written in TypeScript",
  "version": "0.0.10",
  "type": "module",
  "main": "dist/vbs-engine.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": "DevScholar",
  "repository": {
    "type": "git",
    "url": "https://github.com/devscholar/vbs-engine-js.git"
  },
  "bugs": {
    "url": "https://github.com/devscholar/vbs-engine-js/issues"
  },
  "homepage": "https://github.com/devscholar/vbs-engine-js#readme",
  "keywords": [
    "vbs",
    "vbscript",
    "internetexplorer",
    "internet-explorer",
    "ie"
  ],
  "exports": {
    ".": {
      "import": "./dist/vbs-engine.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prepublishOnly": "npm run build",
    "preview": "vite preview",
    "test": "node --experimental-transform-types --experimental-vm-modules node_modules/vitest/vitest.mjs",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.0.0"
  }
}
